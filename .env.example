# === Web search ===
TAVILY_API_KEY=

# === Langfuse v2 (self-hosted) ===
LANGFUSE_HOST=http://langfuse-server:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_DB_PASSWORD=change-me-please
LANGFUSE_NEXTAUTH_SECRET=change-me-please
LANGFUSE_SALT=change-me-please

# === API security ===
CORS_ALLOWED_ORIGINS=http://localhost:8501,http://165.22.192.94
RATE_LIMIT_PER_MINUTE=10

# === Deployment ===
DROPLET_HOST=165.22.192.94
